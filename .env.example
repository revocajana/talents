# Example environment variables for Talents Django backend
# Copy this file to .env and fill in real values.

DJANGO_SECRET_KEY=replace-with-a-secure-secret-key
DJANGO_DEBUG=True

DB_ENGINE=django.db.backends.mysql
DB_NAME=The_database_name
DB_USER=The_database_user
DB_PASSWORD=The_database_password
DB_HOST=localhost
DB_PORT=3306

# Optional: set allowed hosts as a comma-separated list
ALLOWED_HOSTS=localhost,127.0.0.1
